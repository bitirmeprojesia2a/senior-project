# CPU odakli API ornegi
# Bu profil CPU embedding + CPU reranker kullanir.
# Varsayilan olarak mevcut Ollama servisine baglanir.
# Ayrik CPU Ollama kullanilacaksa OLLAMA_HOST daha sonra manuel olarak degistirilir.
# Groq/OpenAI-compatible denemesi icin:
# LLM_PRIMARY_PROVIDER=openai_compatible
# LLM_FALLBACK_PROVIDER=ollama
# OPENAI_API_KEY=<API_KEY>
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-8b-instant
# OPENAI_PROVIDER_NAME=groq

SERVER_PORT=8000
SERVER_RUNTIME_LABEL=cpu
SERVER_DEBUG=false

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_SECONDARY_MODEL=qwen2.5:1.5b
OLLAMA_PRELOAD_MODELS=qwen2.5:1.5b

LLM_PROFILE=fast
LLM_PRIMARY_PROVIDER=ollama
LLM_FALLBACK_PROVIDER=openai_compatible
LLM_ROUTING_MODEL=qwen2.5:1.5b
LLM_CONVERSATION_MODEL=qwen2.5:1.5b

EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=4

CONVERSATION_REWRITE_WITH_LLM=false
SERVER_WARMUP_ENABLED=false
