# CPU odakli API ornegi
# Bu profil CPU embedding + CPU reranker kullanir.
# Groq API uzerinden LLM cagrilari yapilir.

SERVER_PORT=8000
SERVER_RUNTIME_LABEL=cpu
SERVER_DEBUG=false

LLM_PROFILE=fast
LLM_PRIMARY_PROVIDER=openai_compatible
LLM_FALLBACK_PROVIDER=google_ai
LLM_ROUTING_MODEL=
LLM_CONVERSATION_MODEL=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_SECONDARY_MODEL=llama-3.3-70b-versatile
OPENAI_PROVIDER_NAME=groq

EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=4

CONVERSATION_REWRITE_WITH_LLM=false
SERVER_WARMUP_ENABLED=false
