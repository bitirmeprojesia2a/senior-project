# Ayni GPU destekli VM uzerinde GPU odakli API ornegi
# Bu profil GPU embedding + GPU reranker kullanir.

SERVER_PORT=8001
SERVER_RUNTIME_LABEL=gpu
SERVER_DEBUG=false

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_SECONDARY_MODEL=qwen2.5:3b
OLLAMA_PRELOAD_MODELS=qwen2.5:7b,qwen2.5:3b

LLM_PROFILE=balanced
LLM_ROUTING_MODEL=qwen2.5:3b
LLM_CONVERSATION_MODEL=qwen2.5:3b

EMBEDDING_DEVICE=cuda
RERANKER_DEVICE=cuda
RERANKER_BATCH_SIZE=16

CONVERSATION_REWRITE_WITH_LLM=true
SERVER_WARMUP_ENABLED=false
