# GPU destekli VM uzerinde API ornegi
# Bu profil GPU embedding + GPU reranker kullanir.
# LLM cagrilari Groq API uzerinden yapilir.

SERVER_PORT=8001
SERVER_RUNTIME_LABEL=gpu
SERVER_DEBUG=false

LLM_PROFILE=balanced
LLM_PRIMARY_PROVIDER=openai_compatible
LLM_FALLBACK_PROVIDER=google_ai
LLM_ROUTING_MODEL=
LLM_CONVERSATION_MODEL=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_SECONDARY_MODEL=llama-3.3-70b-versatile
OPENAI_PROVIDER_NAME=groq

EMBEDDING_DEVICE=cuda
RERANKER_DEVICE=cuda
RERANKER_BATCH_SIZE=16

CONVERSATION_REWRITE_WITH_LLM=true
SERVER_WARMUP_ENABLED=false
