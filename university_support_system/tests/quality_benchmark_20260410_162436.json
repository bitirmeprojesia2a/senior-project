      "category": "E_process_chain",
      "question": "İlk kez üniversite kaydını yaptıran bir öğrenci olarak ders kaydından danışmanın onayına kadar tüm süreci başından sonuna anlatır mısın?",
      "difficulty": "hard",
      "expected_departments": [
        "student_affairs"
      ],
      "actual_departments": [
        "student_affairs"
      ],
      "dept_match": true,
      "expected_generation_mode": "llm",
