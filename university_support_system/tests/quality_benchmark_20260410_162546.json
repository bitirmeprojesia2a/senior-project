      "id": "Q16",
      "category": "D_comparison",
      "question": "Kayıt dondurma ile kayıt yaptırmamak arasında ne fark var? Her iki durumda da öğrencilik haklarım nasıl etkilenir?",
      "difficulty": "medium",
      "expected_departments": [
        "student_affairs"
      ],
      "actual_departments": [
        "student_affairs"
      ],
      "dept_match": true,
