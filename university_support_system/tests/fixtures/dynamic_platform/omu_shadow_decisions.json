      "expected_agents": ["student_affairs", "academic_programs"],
      "expected_specialists": ["registration_agent", "regulation_agent"],
      "expected_source_families": ["student_policy_documents", "academic_policy_documents"],
      "expected_source_owners": ["student_affairs", "academic_programs"],
      "expected_authority_levels": ["official_policy"],
      "notes": "General CAP eligibility must be represented by policy sources, not by program-specific hardcoded answers."
    },
