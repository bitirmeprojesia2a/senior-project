# ================================================
# Ortam degiskenleri - ornek dosya
# ================================================
# Bu dosyayi `.env` olarak kopyalayip kendi ortaminiza gore duzenleyin.
# FastAPI, uygulama ici A2A akisi, OTP/session auth ve Slack Socket Mode aktiftir.

# -- A2A Transport --
# inprocess: mevcut tek-process davranis
# http: departmanlari /a2a/dispatch endpoint'leri uzerinden cagirir
# shadow: cevap icin inprocess kullanir, HTTP sonucunu arka planda karsilastirir
A2A_MODE=inprocess
A2A_TRANSPORT_PROTOCOL=rest
A2A_TIMEOUT_SECONDS=10
# Main -> department servis cagrilari icin ayri butce. Bos kalirsa A2A_TIMEOUT_SECONDS kullanilir.
A2A_DEPARTMENT_TIMEOUT_SECONDS=
A2A_SPECIALIST_TIMEOUT_SECONDS=60
# Docker canary icin cold-start kaynak/model yuklemesi daha uzun surebilir.
A2A_CANARY_TIMEOUT_SECONDS=30
A2A_INTERNAL_API_KEY=
A2A_REQUIRE_SERVICE_IDENTITY=false
A2A_REQUIRE_REQUEST_SIGNATURE=false
A2A_REQUEST_SIGNATURE_SECRET=
A2A_REQUEST_SIGNATURE_TTL_SECONDS=300
# Ic servis imzasi kullanildiginda beklenen caller id'ler.
A2A_ALLOWED_CALLER_IDS=main_orchestrator,agent-student-affairs,agent-academic,agent-finance
A2A_DISCOVERY_AGENT_CARD_ENABLED=false
A2A_DISCOVERY_AGENT_CARD_TIMEOUT_SECONDS=2
A2A_DISCOVERY_AGENT_CARD_CACHE_SECONDS=60
A2A_EXTERNAL_TRUST_ENABLED=false
# Dis/partner A2A agentlari icin acik allowlist. Format: partner_agent,other_agent
A2A_EXTERNAL_ALLOWED_AGENT_IDS=
# Opsiyonel partner endpoint haritasi. Format: partner_agent=https://partner.example
A2A_EXTERNAL_AGENT_ENDPOINTS=
# External JSON-RPC /a2a istekleri icin per-agent HMAC secret. Format: partner_agent=secret
A2A_EXTERNAL_AGENT_SIGNATURE_SECRETS=
A2A_EXTERNAL_REQUIRE_REQUEST_SIGNATURE=true
A2A_EXTERNAL_REQUEST_SIGNATURE_SECRET=
A2A_EXTERNAL_AGENT_CARD_TIMEOUT_SECONDS=3
A2A_STUDENT_AFFAIRS_URL=http://localhost:8101
A2A_ACADEMIC_PROGRAMS_URL=http://localhost:8102
A2A_FINANCE_URL=http://localhost:8103

# -- Standalone Agent Service --
# scripts/run_agent_service.py ile tek departman servisi calistirmak icin kullanilir.
# Secenekler: student_affairs | academic_programs | finance
AGENT_DEPARTMENT=finance
AGENT_SERVICE_ID=agent-finance
AGENT_PUBLIC_URL=http://localhost:8103

# -- PostgreSQL --
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=university_support
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# -- Redis --
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
USE_REDIS=true

# -- LLM gorev profilleri --
# Profil secenekleri: fast | balanced | quality
LLM_PROFILE=balanced
LLM_PRIMARY_PROVIDER=openai_compatible
LLM_FALLBACK_PROVIDER=google_ai
# Role ozel model override'lari. Bos birakilirsa balansli profil su kuralla calisir:
# routing/conversation -> secondary model, specialist/global -> primary model.
# Bu genel LLM_* override'lari yalnizca primary provider'a uygulanir; farkli provider
# namespace'lerini karistirmamak icin OpenAI/Groq/Google gibi endpoint'lerde provider
# ozel override alanlarini tercih edin.
LLM_ROUTING_MODEL=
LLM_CONVERSATION_MODEL=
LLM_QUERY_EXPANSION_MODEL=
LLM_EVIDENCE_SELECTION_MODEL=
LLM_SPECIALIST_SYNTHESIS_MODEL=
LLM_GLOBAL_SYNTHESIS_MODEL=
LLM_QUERY_NORMALIZATION_ENABLED=true
LLM_QUERY_NORMALIZATION_TIMEOUT_SECONDS=6
LLM_SPECIALIST_SYNTHESIS_TIMEOUT_SECONDS=600
LLM_GLOBAL_SYNTHESIS_TIMEOUT_SECONDS=600

# -- OpenAI-compatible provider (Groq, OpenAI vb.) --
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_SECONDARY_MODEL=llama-3.3-70b-versatile
OPENAI_ROUTING_MODEL=llama-3.3-70b-versatile
OPENAI_CONVERSATION_MODEL=llama-3.3-70b-versatile
OPENAI_QUERY_EXPANSION_MODEL=
OPENAI_SPECIALIST_SYNTHESIS_MODEL=llama-3.3-70b-versatile
OPENAI_GLOBAL_SYNTHESIS_MODEL=llama-3.3-70b-versatile
OPENAI_REASONING_EFFORT=
OPENAI_TIMEOUT=30
OPENAI_PROVIDER_NAME=groq

# -- Google AI Gemini (OpenAI-compatible fallback provider) --
GOOGLE_AI_API_KEY=
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_AI_MODEL=gemini-2.5-flash
GOOGLE_AI_SECONDARY_MODEL=gemini-2.5-flash-lite
GOOGLE_AI_ROUTING_MODEL=
GOOGLE_AI_CONVERSATION_MODEL=
GOOGLE_AI_SPECIALIST_SYNTHESIS_MODEL=
GOOGLE_AI_GLOBAL_SYNTHESIS_MODEL=
GOOGLE_AI_REASONING_EFFORT=none
GOOGLE_AI_TIMEOUT=30
GOOGLE_AI_PROVIDER_NAME=google_ai

# -- ChromaDB --
CHROMA_HOST=localhost
CHROMA_PORT=8100

# -- Embedding modeli --
# Cihaz secenekleri: auto | cpu | cuda
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=auto
EMBEDDING_CUDA_FALLBACK_TO_CPU=true
EMBEDDING_LOCAL_FILES_ONLY=true

# -- Reranker --
# Cihaz secenekleri: auto | cpu | cuda
RERANKER_MODEL=nreimers/mmarco-mMiniLMv2-L6-H384-v1
RERANKER_DEVICE=auto
RERANKER_MAX_LENGTH=512
RERANKER_BATCH_SIZE=16
RERANKER_LOCAL_FILES_ONLY=true

# -- Docker model cache --
# A2A Docker servisleri model cache'i container icinde /models altinda arar.
# Local_files_only=true ise bu dizinde huggingface/hub cache yapisi bulunmalidir.
# Windows'ta mevcut HuggingFace cache icin ornek: C:/Users/<kullanici>/.cache
# Kontrollu online indirme icin kalici bir proje dizini de kullanabilirsiniz.
MODEL_CACHE_HOST_DIR=./data/models

# -- Auth / OTP --
AUTH_OTP_LENGTH=6
AUTH_OTP_TTL_MINUTES=10
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_SESSION_TTL_HOURS=12
AUTH_ALLOWED_STUDENT_EMAIL_DOMAIN=stu.omu.edu.tr

# -- SMTP Email --
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=OMU Destek Sistemi
EMAIL_USE_TLS=true
EMAIL_TIMEOUT_SECONDS=15

# -- RAG --
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_MIN_CHUNK_CHARS=50
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.0
RAG_LLM_QUERY_EXPANSION_ENABLED=false
RAG_LLM_QUERY_EXPANSION_TIMEOUT_SECONDS=8
RAG_LLM_QUERY_EXPANSION_MAX_CHARS=420

# -- Sunucu --
# Uygulama girisi: uvicorn src.api.main:app --host 0.0.0.0 --port 8000
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_PUBLIC_URL=
SERVER_RUNTIME_LABEL=default
SERVER_DEBUG=true
SERVER_LOG_LEVEL=INFO
SERVER_WARMUP_ENABLED=false
SERVER_WARMUP_INCLUDE_RERANKER=false
SERVER_WARMUP_COLLECTIONS=student_affairs_docs,academic_programs_docs

# -- Konusma baglami / follow-up --
CONVERSATION_ENABLED=true
CONVERSATION_TTL_MINUTES=60
CONVERSATION_REWRITE_WITH_LLM=true
CONVERSATION_REWRITE_TIMEOUT_SECONDS=20
CONVERSATION_MAX_SOURCE_REFS=5
CONVERSATION_MAX_TURNS_IN_SUMMARY=6
CONVERSATION_MAX_RECENT_TURNS=3
CONVERSATION_MAX_ANSWER_SUMMARY_CHARS=320
CONVERSATION_MAX_ROLLING_SUMMARY_CHARS=900

# -- Capability Planner (safe rollout) --
# off: legacy behavior only
# shadow: planner runs for diagnostics, legacy answer is returned
# pilot: planner can answer only single routes inside CAPABILITY_PLANNER_SCOPE
# on: planner can answer allowed scopes with legacy fallback
CAPABILITY_PLANNER_MODE=on
# Comma separated: academic_programs,student_affairs,finance,event,announcement
CAPABILITY_PLANNER_SCOPE=academic_programs,student_affairs,finance,announcement,event
CAPABILITY_PLANNER_TIMEOUT_SECONDS=4
CAPABILITY_PLANNER_CONFIDENCE_THRESHOLD=0.45
CAPABILITY_PLANNER_MAX_RECORDS_FOR_SYNTHESIS=40
CAPABILITY_PLANNER_SYNTHESIZE_WITH_LLM=true

# -- Slack --
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
