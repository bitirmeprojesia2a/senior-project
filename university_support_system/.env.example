# ================================================
# Ortam degiskenleri - ornek dosya
# ================================================
# Bu dosyayi `.env` olarak kopyalayip kendi ortaminiza gore duzenleyin.
# FastAPI, uygulama ici A2A akisi ve OTP/session auth aktif durumdadir.
# Slack ve bazi ileri entegrasyonlar halen kismi durumdadir.

# -- PostgreSQL --
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=university_support
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# -- Redis --
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
USE_REDIS=true

# -- Ollama (birincil LLM) --
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# -- OpenAI (yedek LLM) --
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -- ChromaDB --
CHROMA_HOST=localhost
CHROMA_PORT=8100

# -- Embedding modeli --
# Cihaz secenekleri: auto | cpu | cuda
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto

# -- Reranker --
# Cihaz secenekleri: auto | cpu | cuda
RERANKER_MODEL=seroe/bge-reranker-v2-m3-turkish-triplet
RERANKER_DEVICE=auto
RERANKER_MAX_LENGTH=512
RERANKER_BATCH_SIZE=16

# -- Auth / OTP --
AUTH_OTP_LENGTH=6
AUTH_OTP_TTL_MINUTES=10
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_SESSION_TTL_HOURS=12

# -- RAG --
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.0

# -- Sunucu --
# Uygulama girisi: uvicorn src.api.main:app --host 0.0.0.0 --port 8000
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=true
SERVER_LOG_LEVEL=INFO

# -- Slack --
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
