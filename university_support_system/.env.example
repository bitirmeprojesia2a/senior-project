# ================================================
# Ortam Değişkenleri - Örnek Dosya
# ================================================
# Bu dosyayı kopyalayıp .env olarak kaydedin:
#   cp .env.example .env
# Değerleri kendi ortamınıza göre düzenleyin.

# ── PostgreSQL ──────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=university_support
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ── Redis ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
USE_REDIS=true

# ── Ollama (LLM) ───────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── OpenAI (Yedek LLM) ─────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── ChromaDB ────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ── Gömme Modeli ────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3

# ── Reranker ────────────────────────────────────
RERANKER_MODEL=seroe/bge-reranker-v2-m3-turkish-triplet
RERANKER_MAX_LENGTH=512
RERANKER_BATCH_SIZE=16

# ── RAG Ayarları ────────────────────────────────
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.0

# ── Sunucu ──────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=true
SERVER_LOG_LEVEL=INFO

# ── Slack ───────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
