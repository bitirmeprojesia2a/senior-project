# ================================================
# Ortam Değişkenleri - Örnek Dosya
# ================================================
# Bu dosyayı `.env` olarak kopyalayıp kendi ortamınıza göre düzenleyin.
# Varsayılan değerler yerel geliştirme için düşünülmüştür.
# API, Slack, kuyruk ve kimlik doğrulama katmanları bu repoda halen kısmi/iskelet durumdadır.

# -- PostgreSQL --
# Yerel geliştirme varsayılanları.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=university_support
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# -- Redis --
# Redis ayarları hazırdır, ancak aktif retrieval cache uygulama içinde in-memory çalışmaktadır.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
USE_REDIS=true

# -- Ollama (LLM) --
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# -- OpenAI (yedek LLM) --
# Opsiyoneldir. API anahtarı yoksa sistem yalnızca Ollama ile çalışır.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -- ChromaDB --
CHROMA_HOST=localhost
CHROMA_PORT=8100

# -- Gömme modeli --
# Cihaz seçimi: auto | cpu | cuda
# auto seçeneği CUDA varsa GPU, yoksa CPU kullanır.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto

# -- Reranker --
# Cihaz seçimi: auto | cpu | cuda
# Ayrı cihaz atamak isterseniz embedding ve reranker bağımsız yönetilebilir.
RERANKER_MODEL=seroe/bge-reranker-v2-m3-turkish-triplet
RERANKER_DEVICE=auto
RERANKER_MAX_LENGTH=512
RERANKER_BATCH_SIZE=16

# -- RAG ayarları --
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.0

# -- Sunucu --
# Bu repo içinde doğrudan çalıştırılabilir bir FastAPI giriş noktası henüz bulunmamaktadır.
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=true
SERVER_LOG_LEVEL=INFO

# -- Slack --
# Slack bağımlılıkları tanımlıdır, ancak aktif bot entegrasyonu bu repoda henüz tamamlanmamıştır.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
